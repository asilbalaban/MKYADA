{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MKYADA",
  "version": "0.13.0",
  "identifier": "com.mkyada.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MKYADA",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../firmware": "firmware",
      "../resources/circuitpython": "circuitpython"
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
